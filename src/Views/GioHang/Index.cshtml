@model List<TraSuaWeb.Models.GioHangItem>

@{
    ViewData["Title"] = "Giỏ hàng";
    decimal tongTien = 0;
}

<div class="container mt-4">
    <h2 class="text-center text-success mb-4">Giỏ hàng của bạn</h2>

    @if (TempData["ThongBao"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["ThongBao"]
        </div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info text-center">
            Giỏ hàng hiện chưa có sản phẩm nào.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped align-middle">
            <thead class="table-success text-center">
                <tr>
                    <th>Hình ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Size</th>
                    <th>Đơn giá</th>
                    <th style="width:220px;">Số lượng</th>
                    <th>Thành tiền</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    tongTien += item.ThanhTien;

                    <tr>
                        <td class="text-center">
                            <img src="@item.HinhAnh" width="80" />
                        </td>
                        <td>@item.TenSP</td>
                        <td class="text-center">@item.TenSize</td>
                        <td class="text-end">@item.DonGia.ToString("N0") đ</td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center align-items-center gap-2">
                                <a asp-controller="GioHang" asp-action="GiamSoLuong" asp-route-maSp="@item.MaSP" asp-route-maSize="@item.MaSize"
                                   class="btn btn-outline-secondary btn-sm">-</a>

                                <form asp-controller="GioHang" asp-action="CapNhatSoLuong" method="post" class="d-flex align-items-center gap-2">
                                    <input type="hidden" name="maSp" value="@item.MaSP" />
                                    <input type="hidden" name="maSize" value="@item.MaSize" />
                                    <input type="number" name="soLuong" value="@item.SoLuong" min="1"
                                           class="form-control form-control-sm text-center" style="width:70px;" />
                                </form>

                                <a asp-controller="GioHang" asp-action="TangSoLuong" asp-route-maSp="@item.MaSP" asp-route-maSize="@item.MaSize"
                                   class="btn btn-outline-secondary btn-sm">+</a>
                            </div>
                        </td>
                        <td class="text-end">@item.ThanhTien.ToString("N0") đ</td>
                        <td class="text-center">
                            <a asp-controller="GioHang" asp-action="XoaKhoiGio" asp-route-maSp="@item.MaSP" asp-route-maSize="@item.MaSize"
                                   class="btn btn-danger btn-sm">
                                Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="d-flex justify-content-between align-items-center mt-4">
            <h4 class="text-danger mb-0">Tổng tiền: @tongTien.ToString("N0") đ</h4>

            <a asp-controller="GioHang" asp-action="DatHang" class="btn btn-success btn-lg">
                Đặt hàng
            </a>
        </div>
    }
</div>