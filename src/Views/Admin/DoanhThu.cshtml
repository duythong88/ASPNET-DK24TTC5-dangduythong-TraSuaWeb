@model TraSuaWeb.Models.DoanhThuViewModel

@{
    ViewData["Title"] = "Thống kê doanh thu";
}

<div class="container mt-4">
    <h2 class="text-danger mb-4">Thống kê doanh thu</h2>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card text-center shadow-sm p-3 border-0">
                <h5>Doanh thu hôm nay</h5>
                <h3 class="text-danger">@Model.DoanhThuHomNay.ToString("N0") đ</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center shadow-sm p-3 border-0">
                <h5>Doanh thu tháng này</h5>
                <h3 class="text-danger">@Model.DoanhThuThangNay.ToString("N0") đ</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center shadow-sm p-3 border-0">
                <h5>Tổng số đơn đã hoàn tất</h5>
                <h3 class="text-danger">@Model.TongDonHang</h3>
            </div>
        </div>
    </div>

    <div class="card shadow-sm p-4 mb-4">
        <h4 class="mb-3 text-primary">Lọc doanh thu theo khoảng ngày</h4>

        <form method="get" asp-action="DoanhThu">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Từ ngày</label>
                    <input type="date" name="tuNgay" class="form-control"
                           value="@(Model.TuNgay?.ToString("yyyy-MM-dd"))" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Đến ngày</label>
                    <input type="date" name="denNgay" class="form-control"
                           value="@(Model.DenNgay?.ToString("yyyy-MM-dd"))" />
                </div>

                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary">Thống kê</button>
                    <a asp-action="DoanhThu" class="btn btn-secondary">Làm mới</a>
                </div>
            </div>
        </form>

        @if (Model.TuNgay.HasValue && Model.DenNgay.HasValue)
        {
            <div class="mt-4">
                <h5 class="text-success">
                    Doanh thu từ @Model.TuNgay.Value.ToString("dd/MM/yyyy")
                    đến @Model.DenNgay.Value.ToString("dd/MM/yyyy"):
                    <span class="text-danger">@Model.DoanhThuTheoKhoang.ToString("N0") đ</span>
                </h5>
            </div>
        }
    </div>

    <div class="card shadow-sm p-4">
        <h4 class="mb-3 text-warning">Danh sách đơn hàng đã thanh toán</h4>

        <table class="table table-bordered table-striped">
            <thead class="table-warning">
                <tr>
                    <th>Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>Ngày đặt</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Thanh toán</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DanhSachDonHang != null && Model.DanhSachDonHang.Count > 0)
                {
                    @foreach (var dh in Model.DanhSachDonHang)
                    {
                        <tr>
                            <td>@dh.MaDonHang</td>
                            <td>@dh.KhachHang?.TenKH</td>
                            <td>@dh.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@dh.TongTien.ToString("N0") đ</td>
                            <td>
                                <span class="badge bg-primary">@dh.TrangThai</span>
                            </td>
                            <td>
                                <span class="badge bg-success">@dh.ThanhToan</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">Không có dữ liệu doanh thu.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>