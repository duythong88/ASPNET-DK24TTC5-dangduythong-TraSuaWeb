@model List<TraSuaWeb.Models.SanPham>

@{
    ViewData["Title"] = "Sản phẩm";
}

<div class="container mt-4">
    <h2 class="text-center text-primary mb-4">Danh sách sản phẩm</h2>

    <div class="row g-4">
        @foreach (var sp in Model)
        {
            
        var giaNhoNhat = sp.SizeSanPhams != null && sp.SizeSanPhams.Any()
            ? sp.SizeSanPhams.Min(s => s.DonGia)
            : 0;
         var giaLonNhat = sp.SizeSanPhams != null && sp.SizeSanPhams.Any()
            ? sp.SizeSanPhams.Max(s => s.DonGia)
            : 0;
         

            <div class="col-md-4 mb-4">
                <div class="card milktea-card h-100">
                    <div class="product-image-box">
                        <img src="@sp.HinhAnh" class="card-img-top" alt="@sp.TenSP" />
                    </div>

                    <div class="card-body text-center">
                        <h5 class="card-title">@sp.TenSP</h5>
                        <p class="text-danger fw-bold">
                            @if (giaNhoNhat == giaLonNhat)
                            {
                                @(giaNhoNhat.ToString("N0") + " đ")
                            }
                            else
                            {
                                @(giaNhoNhat.ToString("N0") + " - " + giaLonNhat.ToString("N0") + " đ")
                            }
                        </p>


                        <button type="button" class="btn btn-success"
                                onclick="moModalChonSize(@sp.MaSP)">
                            Mua ngay
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="modalChonSize" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">

            <div class="modal-header">
                <h5 class="modal-title">Chọn sản phẩm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form method="post" asp-controller="GioHang" asp-action="ThemVaoGio">
                    <input type="hidden" id="modalMaSP" name="maSp" />

                    <div class="text-center mb-3">
                        <div class="popup-image-box mb-3">
                            <img id="modalHinhAnh" src="" alt="Sản phẩm" />
                        </div>
                        <h5 id="modalTenSP" class="fw-bold"></h5>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Chọn size</label>
                        <select id="modalSize" name="maSize" class="form-select"></select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Số lượng</label>
                        <input type="number" id="modalSoLuong" name="soLuong" class="form-control" value="1" min="1" />
                    </div>

                    <button type="submit" class="btn btn-success w-100">
                        Thêm vào giỏ hàng
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function moModalChonSize(maSp) {

            fetch('/SanPham/LaySize?id=' + maSp)
                .then(res => res.json())
                .then(data => {

                    if (!data) return;

                    document.getElementById("modalMaSP").value = data.maSp;
                    document.getElementById("modalTenSP").innerText = data.tenSp || "";
                    document.getElementById("modalHinhAnh").src = data.hinhAnh || "";
                    document.getElementById("modalSoLuong").value = 1;

                    let select = document.getElementById("modalSize");
                    select.innerHTML = "";

                    data.dsSize.forEach(s => {
                        let option = document.createElement("option");
                        option.value = s.maSize;
                        option.text = s.tenSize + " - " + s.donGia.toLocaleString() + " đ";
                        select.appendChild(option);
                    });

                    var modal = new bootstrap.Modal(document.getElementById('modalChonSize'));
                    modal.show();
                });
        }

        document.addEventListener("DOMContentLoaded", function () {
            let maSp = '@Context.Session.GetInt32("SanPhamDangChon")';

            if (maSp) {
                moModalChonSize(maSp);
                fetch('/SanPham/XoaSession');
            }
        });
    </script>
}