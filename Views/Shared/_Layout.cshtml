<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TraSuaWeb</title>
    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/trasua.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TraSuaWeb.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-sm-0">
                        <li class="nav-item">
                            <a class="nav-link menu-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link menu-link" asp-controller="Home" asp-action="GioiThieu">Giới thiệu</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link menu-link dropdown-toggle"
                                   href="#"
                                   id="sanPhamDropdown"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                Xem Menu
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="sanPhamDropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="SanPham" asp-action="TraSua">Trà sữa</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="SanPham" asp-action="TraTraiCay">Trà trái cây</a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link menu-link" asp-controller="Home" asp-action="LienHe">Liên hệ</a>
                        </li>

                        @if (Context.Session.GetString("LoaiTaiKhoan") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link menu-link" asp-controller="Admin" asp-action="Index">Admin</a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        <a class="btn btn-outline-success" asp-controller="GioHang" asp-action="Index">
                            🛒 Giỏ hàng
                        </a>

                        @if (Context.Session.GetString("TenDangNhap") == null)
                        {
                            <a class="btn btn-outline-primary" asp-controller="TaiKhoan" asp-action="DangNhap">
                                Đăng nhập
                            </a>
                        }
                        else
                        {
                            <span class="me-2 text-dark">
                                Xin chào, @Context.Session.GetString("TenKH")
                            </span>

                            <a class="btn btn-outline-danger" asp-controller="TaiKhoan" asp-action="DangXuat">
                                Đăng xuất
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - TraSuaWeb - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>