@{
    ViewData["Title"] = "Giới thiệu";
}

<div class="container mt-5 mb-5">
    <div class="intro-page">

        <div class="text-center mb-5">
            <h1 class="intro-title">Giới thiệu</h1>
            <p class="intro-subtitle">Về quán trà sữa Phú Quý</p>
        </div>

        <div class="row align-items-center intro-box">
            <div class="col-md-5 mb-4 mb-md-0 text-center">
                <img src="~/images/gioithieu-tra-sua.jpg" alt="Trà sữa Phú Quý" class="img-fluid intro-image" />
            </div>

            <div class="col-md-7">
                <h3 class="mb-3 text-warning fw-bold">Trà Sữa Phú Quý</h3>
                <p class="intro-text">
                    Trà Sữa Phú Quý là địa điểm quen thuộc dành cho những ai yêu thích hương vị trà sữa thơm ngon,
                    đậm đà và đa dạng. Với mong muốn mang đến cho khách hàng những ly thức uống chất lượng,
                    quán luôn lựa chọn nguyên liệu tươi mới, đảm bảo vệ sinh và được chế biến theo quy trình an toàn.
                </p>

                <p class="intro-text">
                    Menu của Trà Sữa Phú Quý phong phú với nhiều loại thức uống hấp dẫn như trà sữa truyền thống,
                    trà sữa matcha, hồng trà sữa, cùng các dòng trà trái cây thanh mát. Đặc biệt, khách hàng có thể
                    lựa chọn nhiều size và topping theo sở thích, mang đến trải nghiệm phù hợp với mọi đối tượng.
                </p>

                <p class="intro-text">
                    Không chỉ chú trọng vào chất lượng sản phẩm, Trà Sữa Phú Quý còn hướng đến phong cách phục vụ nhanh chóng,
                    thân thiện và chuyên nghiệp. Hệ thống đặt hàng online được xây dựng giúp khách hàng dễ dàng lựa chọn món
                    và đặt hàng tiện lợi ngay tại nhà.
                </p>

                <p class="intro-text mb-0">
                    📍 Hiện tại, quán hỗ trợ phục vụ và giao hàng trong khu vực <strong>Đặc khu Phú Quý</strong>,
                    đảm bảo nhanh chóng và tiện lợi cho khách hàng.
                </p>
            </div>
        </div>

        <div class="row text-center mt-5 g-4">
            <div class="col-md-4">
                <div class="intro-feature h-100">
                    <h4>Chất lượng</h4>
                    <p>Nguyên liệu tươi ngon, đảm bảo vệ sinh và hương vị thơm ngon trong từng ly trà.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="intro-feature h-100">
<h4>Phục vụ</h4>
                    <p>Phục vụ nhanh chóng, thân thiện, mang đến trải nghiệm hài lòng cho khách hàng.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="intro-feature h-100">
                    <h4>Giao hàng</h4>
                    <p>Hỗ trợ đặt hàng online và giao nhanh trong khu vực Đặc khu Phú Quý.</p>
                </div>
            </div>
        </div>

    </div>
</div>
