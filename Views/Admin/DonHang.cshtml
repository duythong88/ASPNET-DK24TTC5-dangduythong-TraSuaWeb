@model List<TraSuaWeb.Models.DonHang>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container mt-4">
    <h2 class="text-warning mb-4">Quản lý đơn hàng</h2>

    <table class="table table-bordered table-striped">
        <thead class="table-warning">
            <tr>
                <th>Mã đơn</th>
                <th>Khách hàng</th>
                <th>Ngày đặt</th>
                <th>Địa chỉ</th>
                <th>Số điện thoại</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Thanh toán</th>
                <th style="width: 400px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var dh in Model)
                {
                    <tr>
                        <td>@dh.MaDonHang</td>
                        <td>@dh.KhachHang?.TenKH</td>
                        <td>@dh.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@dh.KhachHang?.DiaChi</td>
                        <td>@dh.KhachHang?.SoDT</td>                      
                        <td>@dh.TongTien.ToString("N0") đ</td>

                        <td>
                       
                                @if (dh.TrangThai == "Chờ xác nhận")
                                {
                                    <span class="badge bg-danger">Chờ xác nhận</span>
                                }
                                else if (dh.TrangThai == "Đã xác nhận")
                                {
                                    <span class="badge bg-success">Đã xác nhận</span>
                                }
                                else if (dh.TrangThai == "Đã giao")
                                {
                                    <span class="badge bg-primary">Đã giao</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@dh.TrangThai</span>
                                }
                            </td>
                            
                       

                        <td>
                            @if (dh.ThanhToan == "Đã thanh toán")
                            {
                                <span class="badge bg-success">Đã thanh toán</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Chờ thanh toán</span>
                            }
                        </td>

                        <td>
                            <a asp-controller="Admin"
                                   asp-action="ChiTietDonHang"
                                   asp-route-id="@dh.MaDonHang"
                                   class="btn btn-info btn-sm">
                                Chi tiết
                            </a>

                            @if (dh.TrangThai == "Chờ xác nhận")
                            {
                                <a asp-controller="Admin"
                                       asp-action="CapNhatTrangThai"
                                       asp-route-id="@dh.MaDonHang"
                                       asp-route-trangThai="Đã xác nhận"
                                       class="btn btn-success btn-sm">
                                    Xác nhận
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-success btn-sm" disabled>Xác nhận</button>
                            }

                            @if (dh.TrangThai != "Đã giao")
                            {
                                <a asp-controller="Admin"
                                       asp-action="CapNhatTrangThai"
                                       asp-route-id="@dh.MaDonHang"
                                       asp-route-trangThai="Đã giao"
                                       class="btn btn-primary btn-sm">
                                    Đã giao
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-primary btn-sm" disabled>Đã giao</button>
                            }

                            @if (dh.ThanhToan == "Đã thanh toán")
                            {
                                <button class="btn btn-dark btn-sm" disabled>Đã thanh toán</button>
                            }
                            else if (dh.TrangThai == "Đã giao")
                            {
                                <a asp-controller="Admin"
                                       asp-action="CapNhatThanhToan"
                                       asp-route-id="@dh.MaDonHang"
                                       class="btn btn-dark btn-sm">
                                    Đã thanh toán
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-dark btn-sm" disabled>Đã thanh toán</button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">Chưa có đơn hàng nào.</td>
                </tr>
            }
        </tbody>
    </table>
</div>