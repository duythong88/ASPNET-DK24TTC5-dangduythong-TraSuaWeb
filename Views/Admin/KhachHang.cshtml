@model List<TraSuaWeb.Models.KhachHang>

@{
    ViewData["Title"] = "Quản lý khách hàng";
}

<div class="container mt-4">
    <h2 class="text-info mb-4">Quản lý khách hàng</h2>

    @if (TempData["ThongBao"] != null)
    {
        <div class="alert alert-success">
            @TempData["ThongBao"]
        </div>
    }

    @if (TempData["ThongBaoLoi"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ThongBaoLoi"]
        </div>
    }

    <table class="table table-bordered table-striped">
        <thead class="table-info">
            <tr>
                <th>Mã KH</th>
                <th>Họ tên</th>
                <th>Email</th>
                <th>Số điện thoại</th>
                <th>Địa chỉ</th>
                <th>Tài khoản</th>
                <th>Loại tài khoản</th>
                <th style="width:120px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var kh in Model)
                {
                    var taiKhoan = kh.TaiKhoans.FirstOrDefault();

                    <tr>
                        <td>@kh.MaKH</td>
                        <td>@kh.TenKH</td>
                        <td>@kh.Email</td>
                        <td>@kh.SoDT</td>
                        <td>@kh.DiaChi</td>
                        <td>@taiKhoan?.TenDangNhap</td>
                        <td>
                            @if (taiKhoan?.LoaiTaiKhoan == "Admin")
                            {
                                <span class="badge bg-danger">Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Khách</span>
                            }
                        </td>
                        <td>
                            <form asp-controller="Admin" asp-action="XoaKhachHang" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@kh.MaKH" />
                                <button type="submit" class="btn btn-danger btn-sm"
                                        onclick="return confirm('Anh có chắc muốn xóa khách hàng này không?');">
                                    Xóa
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center text-muted">Chưa có khách hàng nào.</td>
                </tr>
            }
        </tbody>
    </table>
</div>